# Required only for voice modes (`console`, `dev`, `start`)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_PRESET=budget

# Required for the agent's web-search tool
EXA_API_KEY=

# Optional Prefactor tracing
PREFACTOR_API_URL=
PREFACTOR_API_TOKEN=
PREFACTOR_AGENT_ID=
PREFACTOR_AGENT_NAME=Web Research Agent

# Optional remote end-of-turn detector
LIVEKIT_REMOTE_EOT_URL=

